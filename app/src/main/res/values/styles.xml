<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Styles using SSP -->
    <style name="TextHeadline">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">@dimen/_24ssp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextTitle">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">@dimen/_18ssp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSubtitle">
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>

    <style name="TextBody">
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <!-- Button Styles using SDP -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_48sdp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="cornerRadius">@dimen/_14sdp</item>
    </style>
</resources>
